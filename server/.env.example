# Banking API — copy to server/.env after your domain / SMTP are ready.
# Never commit server/.env (credentials).

# --- SMTP (your provider: Google Workspace, SendGrid, Amazon SES SMTP, Mailgun, etc.) ---
# Leave host/from empty until set — the operator console shows “SMTP not configured”.
# Examples: MAIL_SMTP_HOST=smtp.sendgrid.net   MAIL_FROM=noreply@yourbank.com
MAIL_SMTP_HOST=
MAIL_SMTP_PORT=587
# Use true for port 465 (implicit TLS); false for 587 + STARTTLS (typical)
MAIL_SMTP_SECURE=false
MAIL_SMTP_USER=
MAIL_SMTP_PASS=

# From address (must be allowed by your provider; often needs SPF/DKIM on the domain)
MAIL_FROM=

# Dev / troubleshooting: append the SMTP error text to JSON responses when mail send fails.
# Defaults to ON when NODE_ENV is not production. Production: leave unset or set MAIL_SHOW_SMTP_ERRORS=1 temporarily.
# MAIL_SHOW_SMTP_ERRORS=0

# Optional: Admin → Bank settings → Email delivery (SMTP) saves server/data/smtp-settings.json and
# overrides these MAIL_* values for the running API when that file exists.

# Optional: when a customer submits KYC documents, notify this inbox (requires SMTP above).
# If unset, submissions still save; the server logs that no notify address is configured.
# KYC_NOTIFY_EMAIL=compliance@yourdomain.com

# Email sign-in verification (Settings → Security) sends a 6-digit code via this SMTP.
# If MAIL_SMTP_HOST / MAIL_FROM are missing, users cannot enable OTP or complete OTP sign-in.

# Sign-in email OTP after password (needs working SMTP via MAIL_* or Admin → Email delivery).
# REQUIRE_LOGIN_EMAIL_OTP=1 — send a code for every customer (recommended for production-style demos).
# If unset, only customers who enabled “Email sign-in verification” in Settings get a code.
# SKIP_LOGIN_EMAIL_OTP=1 bypasses OTP for every user (emergency / dev without mail).
# REQUIRE_LOGIN_EMAIL_OTP=1
# SKIP_LOGIN_EMAIL_OTP=1

# Wire transfers: email OTP before approval queue (requires SMTP). Emergency bypass:
# SKIP_WIRE_EMAIL_OTP=1

# Optional: Admin → OTP policy saves server/data/otp-policy.json and overrides the three
# REQUIRE_/SKIP_* flags above for the running API (no restart). Delete that file or use
# Admin → "Use .env defaults" to fall back to this file again.

# Server port (Vite reads NOTIFY_PORT from this file for the /api proxy — restart dev after changes).
# npm run dev:web starts this API automatically if it is not already listening on NOTIFY_PORT.
# If sign-in shows “wrong service on the API port”, pick a free port (e.g. 8805) and restart npm run dev.
# On Render and similar hosts, PORT is set automatically and takes precedence over NOTIFY_PORT.
NOTIFY_PORT=8790

# Production: npm start sets NODE_ENV=production. When dist/index.html exists, this process also
# serves the built SPA from dist/ (same origin as /api). Set BANKING_SERVE_STATIC=0 to serve API only.
# BANKING_SERVE_STATIC=0
# Bind address (default in production is 0.0.0.0 for containers). Example: 127.0.0.1 for local only.
# BANKING_LISTEN_HOST=0.0.0.0

# Browser origins allowed to call this API (comma-separated). Add your production site URL.
# In production, localhost bypass is disabled — list every https:// origin that loads the SPA.
NOTIFY_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Operator console (/admin) — use a long random value; Bearer token for all /api/admin/* routes:
#   GET  /api/admin/overview
#   GET  /api/admin/customers
#   GET  /api/admin/customers/:userId
#   GET  /api/admin/audit-events?limit=100
#   GET/PUT /api/admin/bank-config  |  GET/PUT/DELETE /api/admin/otp-policy
#   GET  /api/admin/approvals  |  GET /api/admin/approvals/:id  |  PATCH /api/admin/approvals/:id
# Approvals: server/data/approvals.json. Customers: server/data/users-store.json.
ADMIN_API_SECRET=

# Optional: PostgreSQL for mirroring audit events (see docker-compose.yml). If unset, audit writes JSONL only.
# DATABASE_URL=postgres://banking:banking@127.0.0.1:5433/banking

# Trust X-Forwarded-For hops when behind a reverse proxy (default 1).
# TRUST_PROXY_HOPS=1
